# Public Supabase values. The anon key is safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only secrets. Keep these out of frontend code and public commits.
OPENROUTER_API_KEY=sk-or-v1-...
HF_TOKEN=hf_...
DATABASE_URL=postgresql://postgres.your-ref:password@aws-1-region.pooler.supabase.com:5432/postgres

# Deployment metadata. Use the real deployed web URL here, not localhost.
NEXT_PUBLIC_APP_URL=https://allai-pink.vercel.app
NEXT_PUBLIC_APP_NAME=ManyAI

# Optional local/test switches.
USE_MOCK_AI=false
